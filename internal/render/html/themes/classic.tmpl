<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>{{.Location}} — HomeLens</title>
<style>
body{font-family:Georgia,'Times New Roman',serif;background:#fbf8f1;color:#3a2e1f;line-height:1.7;margin:0;padding:0}
.wrap{max-width:880px;margin:0 auto;padding:3rem 2rem}
h1{font-size:2.5rem;font-weight:400;font-style:italic;letter-spacing:.01em;border-bottom:2px solid #8b6f47;padding-bottom:.5rem;margin-bottom:.25rem}
.sub{color:#7a6648;font-size:1rem;margin-bottom:2rem}
.rule{height:1px;background:#d4c5a8;margin:2.5rem 0}
h2{font-size:1.5rem;font-weight:400;font-style:italic;color:#5a4628;margin-bottom:1rem;border-bottom:1px solid #d4c5a8;padding-bottom:.3rem}
.criteria{background:#f3ead8;border-left:4px solid #8b6f47;padding:1rem 1.5rem;font-size:.95rem;margin-bottom:2rem}
.criteria div{display:inline-block;margin-right:1.5rem;color:#5a4628}
.stats{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:2rem}
.stat{text-align:center;padding:1rem;border:1px solid #d4c5a8}
.stat .v{font-size:1.6rem;color:#5a4628;font-weight:400}
.stat .l{color:#8b6f47;font-size:.85rem;font-style:italic}
.nbhd-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;margin-bottom:1.5rem}
.nbhd{padding:1rem;border:1px solid #d4c5a8;background:#fff}
.nbhd-head{font-weight:bold;color:#5a4628;margin-bottom:.5rem;font-size:1.05rem;display:flex;justify-content:space-between}
.score{font-style:italic}
.listing{padding:1.5rem 0;border-bottom:1px solid #d4c5a8;display:grid;grid-template-columns:200px 1fr;gap:1.5rem;align-items:start}
.listing img{width:100%;border:1px solid #d4c5a8}
.l-price{font-size:1.6rem;font-weight:400;color:#5a4628}
.l-addr{font-size:1.1rem;font-style:italic;margin:.3rem 0}
.l-specs{color:#7a6648;font-size:.95rem;margin-bottom:.5rem}
.l-meta{font-size:.9rem;color:#7a6648}
.l-cta a{color:#5a4628;text-decoration:underline;margin-right:1rem}
.footer{text-align:center;color:#8b6f47;font-style:italic;font-size:.85rem;margin-top:3rem;padding-top:1rem;border-top:1px solid #d4c5a8}
</style></head><body>
<div class="wrap">
<h1>{{.Location}}</h1>
<div class="sub">A curated home search · {{.Count}} properties · {{.Today}}</div>
<div class="criteria"><div>≥ {{.Filters.MinSqFt}} sqft</div><div>≤ ${{fmtK .Filters.MaxPrice}}</div><div>{{.Filters.MinBeds}}+ bed · {{.Filters.MinBaths}}+ bath</div><div>{{typesList .Filters.Types}}</div></div>
<div class="stats">
<div class="stat"><div class="v">${{fmtK .Stats.MinPrice}}–${{fmtK .Stats.MaxPrice}}</div><div class="l">Price range</div></div>
<div class="stat"><div class="v">${{fmtK .Stats.MedPrice}}</div><div class="l">Median price</div></div>
<div class="stat"><div class="v">{{.Stats.MedSqFt}}</div><div class="l">Median sqft</div></div>
</div>
{{if .MapHTML}}<div class="rule"></div><h2>Map</h2>{{.MapHTML}}{{end}}
{{if .Zips}}<div class="rule"></div><h2>Neighborhoods</h2><div class="nbhd-row">
{{range .SortedZips}}{{$z:=index $.Zips .}}{{$s:=index $.Livability .}}
<div class="nbhd"><div class="nbhd-head"><span>{{.}}</span><span class="score">{{$s}}/100</span></div><div style="font-size:.9rem;color:#7a6648">${{fmtK $z.MedianHouseholdIncome}} median income<br>{{$z.PctBachelorsOrHigher}}% bachelor's+ · {{$z.PovertyPct}}% poverty</div></div>
{{end}}</div>{{end}}
<div class="rule"></div><h2>The Listings</h2>
{{range $i,$h:=.Homes}}{{$liv:=index $.Livability $h.Zip}}
<div class="listing"><div>{{if $h.PhotoURL}}<img src="{{$h.PhotoURL}}" alt="">{{end}}</div>
<div><div class="l-price">${{fmtInt $h.Price.Int}}</div><div class="l-addr">{{$h.StreetLine.String}}{{unitSuffix $h}}, {{$h.City}}, {{$h.State}} {{$h.Zip}}</div>
<div class="l-specs">{{typeName $h.UIPropertyType}} · {{intf $h.Beds}} bed · {{floatf $h.Baths}} bath · {{fmtInt $h.SqFt.Int}} sqft · ${{$h.PricePerSqFt.Int}}/sqft</div>
<div class="l-meta">Built {{$h.YearBuilt.Int}} · {{$h.DOM.Int}} days on market{{if $liv}} · Neighborhood livability: {{$liv}}/100{{end}}</div>
<div class="l-cta" style="margin-top:.6rem"><a href="https://www.redfin.com{{$h.URL}}" target="_blank">View on Redfin →</a><a href="https://www.google.com/maps/search/?api=1&query={{mapsQuery $h}}" target="_blank">View map</a></div></div></div>
{{end}}
<div class="footer">— Generated by HomeLens · Redfin · US Census · city-data.com —</div>
</div></body></html>
